    {
      "title": "Custom VPC and VM Setup",
      "steps": [
        { "description": "Navigate to VPC Network > VPC networks in the Cloud Console." },
        { "description": "Create a VPC named 'mynetwork' with 'Automatic' subnet mode." },
        { "description": "Create two VM instances: 'mynet-us-vm' in us-east1 and 'mynet-eu-vm' in europe-west1." },
        { "description": "Ensure ICMP and SSH firewall rules are enabled for the network." }
      ]
    },
    {
      "title": "VPC Network Peering",
      "steps": [
        { "description": "Create a second VPC named 'privatenet' with a custom subnet." },
        { "description": "Establish a peering connection from 'mynetwork' to 'privatenet'." },
        { "description": "Establish the return peering connection from 'privatenet' to 'mynetwork'." },
        { "description": "SSH into a VM in 'mynetwork' and ping a VM in 'privatenet' using its INTERNAL IP to verify connectivity." }
      ]
    }
  ],
