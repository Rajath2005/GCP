  "tasks": [
    {
      "title": "Setup Topic and Subscription",
      "steps": [
        { "description": "Navigate to Pub/Sub > Topics in the Cloud Console." },
        { "description": "Click 'Create Topic' and name it 'MyTopic'." },
        { "description": "From the topic's context menu (three dots), select 'Create subscription'." },
        { "description": "Name the subscription 'MySub' and select 'Pull' as the delivery type." },
        { "description": "Click 'Create' to establish the message queue." }
      ]
    },
    {
      "title": "Publish and Consume Messages",
      "steps": [
        { "description": "Go to the 'Messages' tab of your 'MyTopic'." },
        { "description": "Click 'Publish Message' and enter 'Hello World' in the message body." },
        { "description": "Open Cloud Shell and pull the message from the subscription.", "command": "gcloud pubsub subscriptions pull --auto-ack MySub" },
        { "description": "Verify that 'Hello World' appears in the Cloud Shell output." }
      ]
    }
  ],
