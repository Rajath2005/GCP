    { "question": "What is Pub/Sub?", "answer": "An asynchronous messaging service that decouples services that produce events from services that process events." },
    { "question": "Push vs Pull delivery?", "answer": "Push delivers messages to a webhook URL. Pull requires the subscriber to request messages from the service." }
  ],
