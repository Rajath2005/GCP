      "steps": [
        { "description": "Enable the App Engine Admin API in the API Library." },
        { "description": "Clone the sample repository in Cloud Shell.", "command": "git clone https://github.com/GoogleCloudPlatform/python-docs-samples.git\ncd python-docs-samples/appengine/standard_python3/hello_world" },
        { "description": "Deploy the application.", "command": "gcloud app deploy" },
        { "description": "View the live application.", "command": "gcloud app browse" }
      ]
    },
    {
      "title": "Deploy to App Engine Flexible",
      "steps": [
        { "description": "Download the flexible environment sample code.", "command": "gcloud storage cp -r gs://spls/gsp023/flex_and_vision/ ." },
        { "description": "Create a Cloud Storage bucket for the app.", "command": "gsutil mb gs://${PROJECT_ID}" },
        { "description": "Update 'app.yaml' with your bucket name." },
        { 
          "description": "Deploy the application to the Flexible environment (this may take several minutes).",
          "command": "gcloud app deploy"
        }
      ]
    }
